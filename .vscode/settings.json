{

  /* Vertical guidelines for line wrapping. */
  "editor.rulers": [
    80,
    100,
    120,
  ],

  /* By default, wrap long lines at the viewport or 120 characters,
  whichever is narrowest. */
  "editor.wordWrap": "bounded",
  "editor.wordWrapColumn": 120,

  /* Show control and empty space characters. */
  "editor.renderControlCharacters": true,
  "editor.renderWhitespace": "all",

  /* Enforce 2 spaces for indentation by default. */
  "editor.detectIndentation": false,
  "editor.insertSpaces": true,
  "editor.tabSize": 2,

  /* Enable auto-formatting by default. */
  "editor.formatOnPaste": true,
  "editor.formatOnSave": true,
  "editor.formatOnType": false,

  /* Disable auto-fixes by default. */
  "editor.codeActionsOnSave": {
    "source.fixAll": "never",
    "source.fixAll.shellcheck": "explicit",
  },

  /*
  LANGUAGE-SPECIFIC OVERRIDES
  */

  "[asciidoc]": {
    "editor.rulers": [
      100
    ],
    "editor.wordWrap": "bounded",
    "editor.wordWrapColumn": 100,

    "editor.formatOnPaste": true,
    "editor.formatOnSave": true,
    "editor.formatOnType": true,
  },

  "[json]": {
    "editor.formatOnPaste": false,
    "editor.formatOnSave": false,
    "editor.formatOnType": false,
  },

  "[jsonc]": {
    "editor.formatOnPaste": false,
    "editor.formatOnSave": false,
    "editor.formatOnType": false,
  },

  "[python]": {
    "editor.rulers": [
      88
    ],
    "editor.wordWrap": "bounded",
    "editor.wordWrapColumn": 88,
  },

  /*
  GIT SETTINGS
  */

  /* Always prompt before committing to a protected branch. */
  "git.branchProtectionPrompt": "alwaysPrompt",
  "git.branchProtection": [
    // "stable",
    // "release/*",
  ],

  /*
  EXTENSION SETTINGS
  The following settings are applicable for the extensions listed in
  the extension recommendations in `extensions.json`.
  */

  /*
  Asciidoc extension.
  https://marketplace.visualstudio.com/items?itemName=asciidoctor.asciidoctor-vscode
  */

  /* Disable Antora support. */
  "asciidoc.antora.showEnableAntoraPrompt": false,

  /* When previewing Asciidoc files, use VS Code's workbench color theme,
  rather than the default Asciidoc style. This ensures the colors of the
  preview are consistent with the enabled VS Code theme. */
  "asciidoc.preview.useEditorStyle": true,

  /*
  Python extension.
  https://marketplace.visualstudio.com/items?itemName=ms-python.python
  */

  /* Disable some of Pylance's intensive features – which can crash WSL on
  resource-limited systems. */
  "python.languageServer": "Pylance",
  "python.analysis.indexing": false,
  "python.analysis.packageIndexDepths": [],

}
