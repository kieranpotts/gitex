#!/bin/env sh
set -eu

#
# git-pick - Shortcut for `git cherry-pick`. Options are forwarded.
#
# Usage:
#   $ git pick [...]
#
# Dependencies: None
#

# shellcheck source=../lib/print.sh
. "$(dirname "$0")/../lib/print.sh"

main() {
  if [ $# -gt 0 ]; then
    print_error "git-pick does not accept any options"
    return 1
  fi

  # TODO: Review draft implementation, below.

  # Bash-compatible code, with string indexing that allows additional options
  # to be passed on to the `git cherry-pick` command.
  #git cherry-pick ${@:1}

  # POSIX-compatible code, without string indexing. This code only passes the
  # first option to the `git cherry-pick` command.
  git cherry-pick "${1}"

}

main "$@"
