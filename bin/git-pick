#!/bin/env sh
set -eu

#
# git-pick - Shortcut for `git cherry-pick`. Parameters are forwarded.
#
# Usage:
#   $ git pick ([params...\])
#
# Dependencies: None
#

main() {
  if [ $# -gt 0 ]; then
    echo "error: git-pick does not accept any arguments" >&2
    return 1
  fi

  # git cherry-pick "$@"
}

main "$@"
