#!/bin/env sh
set -eu

#
# git-filelog - List all the commits that have changed the specified file.
#
# Usage:
#   $ git filelog [<path>]
#
# Dependencies: None
#

# shellcheck source=../lib/print.sh
. "$(dirname "$0")/../lib/print.sh"

main() {
  if [ $# -gt 0 ]; then
    print_error "git-filelog does not accept any options"
    return 1
  fi

  # TODO: Review draft implementation, below.

  file="${1}"

  if [ -z "${file}" ]; then
    # Bash-compatible code:
    #read -p "Type a file path: " file

    # Posix-compatible code:
    printf "Type a file path: " >&2
    read -r file
  fi

  if [ -z "${file}" ]; then
    echo "Require a file path" >&2
    exit 1
  fi

  git log --graph --pretty=format:'%C(red)%h%C(reset)  %<(60,trunc)%s  %C(green)%<(14)%ar  %C(blue)%an %C(yellow)%d%C(reset)' --abbrev-commit -- "${file}"
}

main "$@"
