#!/bin/env sh
set -eu

#
# git-configure - Open `~/.gitconfig` in your default text editor.
#
# Usage:
#   $ git configure
#
# Dependencies: None
#

# shellcheck source=../lib/print.sh
. "$(dirname "$0")/../lib/print.sh"

main() {
  if [ $# -gt 0 ]; then
    print_error "git-configure does not accept any arguments"
    return 1
  fi

  # git config --global --edit
}

main "$@"
