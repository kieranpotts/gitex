#!/bin/env sh
set -eu

#
# git-co - Shortcut for `git checkout`. Parameters are forwarded.
#
# Usage:
#   $ git co ([params...])
#
# Dependencies: None
#

main() {
  if [ $# -gt 0 ]; then
    echo "error: git-co does not accept any arguments" >&2
    return 1
  fi

  # git checkout "$@"
}

main "$@"
