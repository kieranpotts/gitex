#!/bin/env sh
set -eu

#
# git-co - Shortcut for `git checkout`. Parameters are forwarded.
#
# Usage:
#   $ git co ([params...])
#
# Dependencies: None
#

# shellcheck source=../lib/print.sh
. "$(dirname "$0")/../lib/print.sh"

main() {
  if [ $# -gt 0 ]; then
    print_error "git-co does not accept any arguments"
    return 1
  fi

  # Bash-compatible code, with string indexing that allows additional parameters
  # to be passed on to the `git checkout` command.
  #git checkout ${@:1}

  # POSIX-compatible code, without string indexing. This code only passes the
  # first parameter to the `git checkout` command.
  git checkout "${1}"

}

main "$@"
