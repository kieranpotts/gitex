#!/bin/env sh
set -eu

#
# gitex - Get help with using GitEx.
#
# Usage:
#   $ gitex
#
# Options:
#   -v, --version   Show installed GitEx version number
#   -c, --commands  List available GitEx aliases
#   -h, --help      Show usage instructions
#
# Dependencies: None
#

_print_help() {
  cat <<EOF
Usage: gitex [options]

Get help with using GitEx.

Options:
  -v, --version   Show installed GitEx version number
  -c, --commands  List available GitEx aliases
  -h, --help      Show usage instructions

Examples:
  $ git gitex --version
  $ git gitex --commands
  $ git -h
EOF
}

# shellcheck source=lib/print.sh
. "$(dirname "$0")/../lib/print.sh"

_print_version() {
  # Extract version from pyproject.toml.
  version=$(grep '^version = ' "$(dirname "$0")/../pyproject.toml" | sed 's/version = "\(.*\)"/\1/')
  if [ -z "$version" ]; then
    version="unknown"
  fi
  echo "GitEx v$version"
}

_print_commands() {
  cat <<EOF

GitEx commands:

  git amend
    Add staged or working changes to last commit.

  git author ([ref]) (--name [name]) (--email [email])
    Change the author of the last commit, or an earlier specified commit.

  git unamend
    Undo the prior 'git amend' operation.

  git uncommit
    Undo the last commit, return the changes to the staging index.

  git whoami
    Show the currently configured Git user.

EOF
}

main() {
  if [ $# -eq 1 ]; then
    case "$1" in
      -v|--version)
        _print_version
        return 0
        ;;
      -c|--commands)
        _print_commands
        return 0
        ;;
      -h|--help)
        _print_help
        return 0
        ;;
      *)
        print_error "unknown option: $1"
        print_hint "Try 'gitex --help' for more information."
        return 1
        ;;
    esac
  fi

  # If no arguments, show help.
  if [ $# -eq 0 ]; then
    _print_help
    return 0
  fi

  # Too many arguments.
  print_error "too many arguments"
  print_hint "Try 'gitex --help' for more information."
  return 1
}

main "$@"
