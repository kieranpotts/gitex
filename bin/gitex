# gitex - Get help with GitEx commands.
#
# Usage:
#   $ gitex
#
# Options:
#   -g, --global    Show global Git config
#   -l, --local     Show local Git config (default)
#   -a, --all       Show both local and global config
#   -h              Show help information
#
# Dependencies: None
#

_print_help() {
  cat <<EOF
Usage: git whoami [options]

Show the currently configured Git user name and email.

Options:
  -g, --global    Show global Git config
  -l, --local     Show local Git config (default)
  -a, --all       Show both local and global config

Examples:
  git whoami              Show local config
  git whoami --global     Show global config
  git whoami --all        Show both local and global config
EOF
}

