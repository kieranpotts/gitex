#!/bin/env sh
set -eu

#
# git-uncommit - Undo the last commit, returning the changes introduced in the
# commit to the staging index, ready to be re-committed.
#
# Combine with `git undo` to fully delete the changes. Running both commands,
# `git uncommit && git undo`, is equivalent to doing `git reset HEAD~1 --hard`.
#
# Usage:
#   $ git uncommit
#
# Dependencies: None
#

# shellcheck source=../lib/print.sh
. "$(dirname "$0")/../lib/print.sh"

main() {
  if [ $# -gt 0 ]; then
    print_error "git-uncommit does not accept any options"
    return 1
  fi

  git reset HEAD~1 --soft
}

main "$@"
