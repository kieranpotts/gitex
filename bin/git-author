#!/bin/env sh
set -eu

#
# git-author - Change the name and email of the author of the last commit, or
# an earlier specified commit in the checked-out branch's history.
#
# Usage:
#   $ git author ([ref]) (--name [name]) (--email [email])
#
# Dependencies: None
#


# Source print helper functions.
# shellcheck source=lib/print.sh
. "$(dirname "$0")/../lib/print.sh"

main() {

  # Parse arguments.
  ref=""
  author_name=""
  author_email=""

  while [ $# -gt 0 ]; do
    case "$1" in
      --name)
        if [ $# -lt 2 ] || [ -z "${2:-}" ] || [ "${2#--}" != "$2" ]; then
          print_error "--name requires a value"
          return 1
        fi
        author_name="$2"
        shift 2
        ;;
      --email)
        if [ $# -lt 2 ] || [ -z "${2:-}" ] || [ "${2#--}" != "$2" ]; then
          print_error "--email requires a value"
          return 1
        fi
        author_email="$2"
        shift 2
        ;;
      -*)
        print_error "unknown option '$1'"
        return 1
        ;;
      *)
        if [ -z "$ref" ]; then
          ref="$1"
        else
          print_error "unexpected argument '$1'"
          return 1
        fi
        shift
        ;;
    esac
  done

  # Get the name of the current branch.
  branch=$(git branch --show-current)

  # Target revision (defaults to HEAD if not specified).
  rev=$(git rev-parse "${ref:-HEAD}")

  # Check if we're modifying HEAD directly.
  head_rev=$(git rev-parse HEAD)

  if [ "$rev" = "$head_rev" ]; then
    # Simple case: modifying the current HEAD commit.
    # No need to checkout or rebase.

    # Prompt for author name if not provided.
    if [ -z "$author_name" ]; then
      print_prompt "Author's name (leave empty to use your default user.name config):"
      read -r author_name
      echo ""
    fi

    # If name is empty, use --reset-author to apply default config.
    if [ -z "${author_name}" ]; then
      git commit --quiet --amend --reset-author --no-edit
    else
      # Prompt for email if not provided.
      if [ -z "$author_email" ]; then
        print_prompt "Author's email address:"
        read -r author_email
        echo ""
      fi

      # Email is required when name is provided.
      if [ -z "${author_email}" ]; then
        print_error "Email not provided, exiting."
        exit 1
      fi

      # Amend commit with new author.
      git commit --quiet --amend --author "${author_name} <${author_email}>" --no-edit
    fi

    # Output the new commit hash.
    print_info "New commit hash is $(git rev-parse HEAD)."

  else
    # Complex case: modifying an earlier commit.
    # Need to checkout, amend, and rebase.

    # Checkout the target commit. Git repo enters a "detached HEAD" state.
    git checkout --quiet "${rev}"

    # Prompt for author name if not provided.
    if [ -z "$author_name" ]; then
      print_prompt "Author's name (leave empty to use your default user.name config):"
      read -r author_name
      echo ""
    fi

    # If name is empty, use --reset-author to apply default config.
    if [ -z "${author_name}" ]; then
      git commit --quiet --amend --reset-author --no-edit
    else
      # Prompt for email if not provided.
      if [ -z "$author_email" ]; then
        print_prompt "Author's email address:"
        read -r author_email
        echo ""
      fi

      # Email is required when name is provided.
      if [ -z "${author_email}" ]; then
        print_error "Email not provided, exiting."
        exit 1
      fi

      # Amend commit with new author.
      git commit --quiet --amend --author "${author_name} <${author_email}>" --no-edit
    fi

    # New commit hash.
    new_rev=$(git rev-parse HEAD)
    print_info "New commit hash is ${new_rev}."

    # Switch back to the previous branch then rebase on the new revision.
    git switch --quiet "${branch}"
    git rebase "${new_rev}"
  fi
}

main "$@"
