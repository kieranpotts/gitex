#!/bin/env sh
set -eu

#
# git-current - Show the name of the current branch.
#
# See also the `git upstream` alias, which returns the name of the tracked
# upstream branch.
#
# Usage:
#   $ git current
#
# Dependencies: None
#

# shellcheck source=../lib/print.sh
. "$(dirname "$0")/../lib/print.sh"

main() {
  if [ $# -gt 0 ]; then
    print_error "git-current does not accept any arguments"
    return 1
  fi

  # Git < 2.22
  # git rev-parse --abbrev-ref HEAD

  # Git >= 2.22
  git branch --show-current

}

main "$@"
