#!/bin/env sh
set -eu

#
# git-track - Start tracking one or more new files. This is an alias for
# `git add` and the opposite of the `git untrack` alias.
#
# Options are forwarded.
#
# Usage:
#   $ git track [<path>] [--all|-A]
#
# Examples:
#   # Add all changes in whole working tree.
#   $ git track (--all|-A)
#
#   # Add all changes in current path.
#   $ git track .
#
#   # Add one or more specific files.
#   $ git track path/to/file.ext
#
# Dependencies: (none)
#

# shellcheck source=../lib/print.sh
. "$(dirname "$0")/../lib/print.sh"

main() {
  if [ $# -gt 0 ]; then
    print_error "git-track does not accept any options"
    return 1
  fi

  # TODO: Review draft implementation, below.

  path="${1}"

  if [ -z "${path}" ]; then
    git add --all
  else
    git add "${path}"
  fi
}

main "$@"
