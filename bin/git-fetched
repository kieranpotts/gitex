#!/bin/env sh
set -eu

#
# git-fetched - List the commits added since the last update to HEAD.
#
# This command is useful to see what has been committed locally since the last
# `git fetch` operation.
#
# Additional options will be passed to `git log`. Append `--no-merges` to
# exclude merge commits from the log.
#
# Usage:
#   $ git fetched
#
# Dependencies: None
#

# shellcheck source=../lib/print.sh
. "$(dirname "$0")/../lib/print.sh"

main() {
  if [ $# -gt 0 ]; then
    print_error "git-fetched does not accept any options"
    return 1
  fi

  # TODO: Review draft implementation, below.

  # git log --oneline --no-decorate --no-merges @{upstream}..HEAD

  # Bash-compatible code, with string indexing that allows additional options
  # to be passed on to the `git log` command.
  #git log ORIG_HEAD.. --graph --pretty=format:'%C(red)%h%C(reset)  %<(60,trunc)%s  %C(green)%<(14)%ar  %C(blue)%an %C(yellow)%d%C(reset)' --abbrev-commit ${@:1}

  # POSIX-compatible code, without string indexing. This code only passes the
  # first options to the `git log` command.
  git log ORIG_HEAD.. --graph --pretty=format:'%C(red)%h%C(reset)  %<(60,trunc)%s  %C(green)%<(14)%ar  %C(blue)%an %C(yellow)%d%C(reset)' --abbrev-commit "${1}"
}

main "$@"
