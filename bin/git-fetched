#!/bin/env sh
set -eu

#
# git-fetched - List the commits added by the last `git fetch` operation.
#
# Usage:
#   $ git fetched
#
# Dependencies: None
#

main() {
  if [ $# -gt 0 ]; then
    echo "error: git-fetched does not accept any arguments" >&2
    return 1
  fi

  # git log --oneline --no-decorate --no-merges @{upstream}..HEAD
}

main "$@"
