#!/bin/env sh
set -eu

#
# git-whoami - Show the currently configured Git user.
#
# Local repository and global configuration are considered.
# If no user is configured, "[not set]" is shown.
#
# Usage:
#   $ git whoami
#
# Dependencies: None
#

main() {
  if [ $# -gt 0 ]; then
    echo "error: git-whoami does not accept any arguments" >&2
    echo "usage: git whoami" >&2
    return 1
  fi

  name=$(git config --get user.name 2>/dev/null)
  email=$(git config --get user.email 2>/dev/null)

  if [ -z "${name}" ]; then
    name="[not set]"
  fi

  if [ -z "${email}" ]; then
    email="[not set]"
  fi

  echo "name:  ${name}"
  echo "email: ${email}"
}

main "$@"
