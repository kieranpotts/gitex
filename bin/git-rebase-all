#!/bin/env sh
set -eu

#
# git-rebase-all - Rebase all local branches on the trunk branch. Defaults
# to using the `main` branch as the target base branch, unless otherwise
# specified.
#
# Usage:
#   $ git rebase-all ([trunk])
#
# Dependencies: None
#

# shellcheck source=../lib/print.sh
. "$(dirname "$0")/../lib/print.sh"

main() {
  if [ $# -gt 0 ]; then
    print_error "git-rebase-all does not accept any arguments"
    return 1
  fi

  # TODO: Review draft implementation, below.

  # Get the name of the trunk branch, default to main.
  trunk_branch=${1:-main}

  # Get the names of all local branches except the trunk branch
  branches=$(git branch --format='%(refname:short)' | grep -v "^${trunk_branch}$")

  # Rebase each branch on the trunk branch.
  for branch in ${branches}; do
    git checkout "${branch}"
    git rebase "${trunk_branch}"
  done

  # Switch back to the trunk branch.
  git checkout "${trunk_branch}"
}

main "$@"
