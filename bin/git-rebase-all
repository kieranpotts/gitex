#!/bin/env sh
set -eu

#
# git-rebase-all - Rebase all local branches on a base branch. Defaults
# to using the `main` branch as the target base branch, unless otherwise
# specified.
#
# Usage:
#   $ git rebase-all [<base>]
#
# Dependencies: None
#

# shellcheck source=../lib/print.sh
. "$(dirname "$0")/../lib/print.sh"

main() {
  if [ $# -gt 0 ]; then
    print_error "git-rebase-all does not accept any options"
    return 1
  fi

  # TODO: Review draft implementation, below.

  # Get the name of the base branch, default to main.
  base_branch=${1:-main}

  # Get the names of all local branches except the base branch
  branches=$(git branch --format='%(refname:short)' | grep -v "^${base_branch}$")

  # Rebase each branch on the base branch. Set the original author date (which
  # is preserved by default) as the new committer date (which would otherwise
  # be reset to the current time).
  for branch in ${branches}; do
    git checkout "${branch}"
    git rebase --committer-date-is-author-date "${base_branch}"
  done

  # Switch back to the base branch.
  git checkout "${base_branch}"
}

main "$@"
