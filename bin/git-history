#!/bin/env sh
set -eu

#
# git-history - Clean `git log`, paginated.
#
# See also `git recent`, which limits the output to the last 25 log entries.
#
# Usage:
#   $ git history
#
# Dependencies: None
#

# shellcheck source=../lib/print.sh
. "$(dirname "$0")/../lib/print.sh"

main() {
  if [ $# -gt 0 ]; then
    print_error "git-history does not accept any arguments"
    return 1
  fi

  # TODO: Review draft implementation, below.

  git log --graph --pretty=format:'%C(red)%h%C(reset)  %<(60,trunc)%s  %C(green)%<(14)%ar  %C(blue)%an %C(yellow)%d%C(reset)' --abbrev-commit
}

main "$@"
