#!/bin/env sh
set -eu

#
# git-discard - Discard working changes to one or more files. Changes
# made will be lost indefinitely.
#
# Usage:
#   $ git discard [paths...]
#
# Dependencies: None
#

main() {
  if [ $# -gt 0 ]; then
    echo "error: git-discard does not accept any arguments" >&2
    return 1
  fi

  # git checkout -- "$@"
}

main "$@"
