#!/bin/env sh
set -eu

#
# git-ignored - Print a list of file paths, changes to which cannot be
# added to Git's staging index because Git will ignore them.
#
# Use `git ignore [path]` to add a file path to this list, or
# `git unignore [path]` to remove one.
#
# Usage:
#   $ git ignored
#
# Dependencies: (none)
#

# shellcheck source=../lib/print.sh
. "$(dirname "$0")/../lib/print.sh"

main() {
  if [ $# -gt 0 ]; then
    print_error "git-ignored does not accept any options"
    return 1
  fi

  # TODO: Review draft implementation, below.

  git ls-files --ignored --exclude-standard

  # Or:

  # printf "%bChanges to the following files will not be available to add to the staging index:%b" "${BRIGHT_BLUE}" "${RESET}"
  # git ls-files -v | grep "^[[:lower:]]"
}

main "$@"
