#!/bin/env sh
set -eu

#
# git-upstream - Show the name of the tracked upstream repository.
#
# Silences fatal "no upstream configured" errors in scenarios where no upstream
# repository is configured.
#
# Use `git tracking` to list all tracked branches.
#
# Usage:
#   $ git upstream
#
# Dependencies: None
#

# shellcheck source=../lib/print.sh
. "$(dirname "$0")/../lib/print.sh"

main() {
  if [ $# -gt 0 ]; then
    print_error "git-upstream does not accept any options"
    return 1
  fi

  # TODO: Review draft implementation, below.

  git rev-parse --abbrev-ref --symbolic-full-name "@{upstream}" 2> /dev/null
}

main "$@"
