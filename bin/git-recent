#!/bin/env sh
set -eu

#
# git-recent - Clean `git log`, last 25 entries only.
#
# This is identical to `git history` except the output is
# restricted to the last 25 entries, and therefore is not paged.
#
# Usage:
#   $ git recent
#
# Dependencies: None
#

# shellcheck source=../lib/print.sh
. "$(dirname "$0")/../lib/print.sh"

main() {
  if [ $# -gt 0 ]; then
    print_error "git-recent does not accept any arguments"
    return 1
  fi

  # TODO: Review draft implementation, below.

  git log --graph --pretty=format:'%C(red)%h%C(reset)  %<(60,trunc)%s  %C(green)%<(14)%ar  %C(blue)%an %C(yellow)%d%C(reset)' --abbrev-commit --max-count=25
}

main "$@"
