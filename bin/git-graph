#
# Usage:
#   $ git graph
#
# Dependencies: None
#

# shellcheck source=../lib/print.sh
. "$(dirname "$0")/../lib/print.sh"

main() {
  if [ $# -gt 0 ]; then
    echo "error: git-graph does not accept any arguments" >&2
    return 1
  fi

  # git log --oneline --decorate --graph --all
}

main "$@"
