#!/bin/env sh
set -eu

#
# git-graph - Show a detailed graphical representation of the commit
# history; alternative to `git log`.
#
# Usage:
#   $ git graph
#
# Dependencies: (none)
#

# shellcheck source=../lib/print.sh
. "$(dirname "$0")/../lib/print.sh"

main() {
  if [ $# -gt 0 ]; then
    print_error "git-graph does not accept any options"
    return 1
  fi

  # TODO: Review draft implementation, below.

  git log --oneline --decorate --graph --all
}

main "$@"
