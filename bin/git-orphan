#!/bin/env sh
set -eu

#
# git-orphan - Create an orphaned branch, with no parents, and switch to it.
#
# Working changes will be added to the staging index, unless the `--fresh`
# option is provided, in which case the working directory will be
# cleared – careful, you may lose work-in-progress.
#
# This is useful to start a fresh trunk that is not based on any previous
# work. You might use this, for example, to create a `gh-pages` branch as
# a build target, but which is otherwise unconnected to the history of
# the source branches.
#
# Note: unlike the branching aliases, the new branch cannot be immediately
# synced with the upstream reference repository. That's because, until there is
# at least one commit in the orphaned branch's history, there is no HEAD
# reference.
#
# Usage:
#   $ git orphan [<branch>] [--fresh]
#
# Dependencies: None
#

# shellcheck source=../lib/print.sh
. "$(dirname "$0")/../lib/print.sh"

_print_usage() {
  cat <<EOF
Usage: git-orphan <branch-name> [--fresh]

Creates a new branch that has no parent commits.
--fresh: Removes all files from the working directory (keeps .git)
EOF
}

main() {

  # TODO: If there are working/staged changes, prompt the use to keep or
  # discard them.

  # Parse arguments.
  branch=""
  fresh=false

  while [ $# -gt 0 ]; do
    case "$1" in
      --fresh) fresh=true ;;
      -h|--help) usage ;;
      *)
        if [ -z "${branch}" ]; then
          branch="$1"
        else
          print_error "Unknown argument: $1"
        fi
        ;;
    esac
    shift
  done

  if [ -z "${branch}" ]; then
    # Bash-compatible code:
    #read -p "Type a branch name: " branch

    # Posix-compatible code:
    printf "Type a branch name: " >&2
    read -r branch
  fi

  if [ -z "${branch}" ]; then
    print_error "Require branch name"
    exit 1
  fi

  # Create the orphan branch. `git checkout --orphan` creates a branch with no
  # history and stages all current files in the index.
  if ! git checkout --orphan "${branch}"; then
    error "Failed to create orphan branch '${branch}'"
  fi

  # Handle the `--fresh` flag. If the user wants a totally clean slate, we
  # clear the index and working tree. We don't use `git clean`, to avoid
  # deleting untracked files. But the index is now empty.
  if [ "${fresh}" = true ]; then
    git rm -rf .
  fi

}

main "$@"
