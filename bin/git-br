#!/bin/env sh
set -eu

#
# git-br - Branch from current position, switch to it, and push upstream
# immediately, establishing remote tracking from the start of the branch's
# existence.
#
# This operation fails with an error if the branch name is already taken.
#
# Usage:
#   $ git br [<branch>]
#
# Dependencies: None
#

# shellcheck source=../lib/print.sh
. "$(dirname "$0")/../lib/print.sh"

main() {
  # Get branch name from argument or prompt for it.
  if [ $# -eq 0 ]; then
    # No argument provided, prompt for branch name.
    print_prompt "Enter branch name:"
    read -r branch
  elif [ $# -eq 1 ]; then
    # Branch name provided as argument.
    branch="$1"
  else
    # Too many arguments.
    print_error "git-br accepts at most one argument (branch name)"
    return 1
  fi

  # Validate branch name is not empty.
  if [ -z "${branch}" ]; then
    print_error "Branch name cannot be empty"
    return 1
  fi

  # Create and checkout the new branch.
  git branch "${branch}" && git checkout "${branch}"

  # Determine the remote name to use (customizable via environment variable).
  remote="${X_GITEX_DEFAULT_REMOTE_NAME:-origin}"

  # Push to remote and set up tracking.
  git push --set-upstream "${remote}" HEAD
}

main "$@"
