#!/bin/env sh
set -eu

#
# git-br - Branch from current position, switch to it, and push upstream
# immediately, establishing remote tracking from the start of the branch's
# existence.
#
# This operation fails with an error if the branch name is already taken.
#
# Usage:
#   $ git br ([branch])
#
# Dependencies: None
#

# shellcheck source=../lib/print.sh
. "$(dirname "$0")/../lib/print.sh"

main() {
  if [ $# -gt 0 ]; then
    print_error "git-br does not accept any arguments"
    return 1
  fi

  # TODO: Review draft implementation, below.

  branch="${1}"

  if [ -z "${branch}" ]; then
    # Bash-compatible code:
    #read -p "Type a branch name: " branch

    # Posix-compatible code:
    printf "> " >&2
    read -r branch
  fi

  if [ -z "${branch}" ]; then
    printf "%b%b Require branch name. %b\n" "${RED}" "${REVERSED}" "${RESET}" >&2
    exit 1
  fi

  git branch "${branch}" && git checkout "${branch}"

  # Don't push temporary branches.
  # TODO: Allow this to be customized through environment variables.
  if [ "${branch}" != "tmp" ]; then
    git push --set-upstream origin HEAD
  fi
}

main "$@"
