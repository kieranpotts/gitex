#!/bin/env sh
set -eu

#
# git-tags - List all tags, sorted by commit date.
#
# Use `git download` to download all tags, as well as branches, from the
# upstream repository.
#
# Usage:
#   $ git tags
#
# Dependencies: None
#

# shellcheck source=../lib/print.sh
. "$(dirname "$0")/../lib/print.sh"

main() {
  if [ $# -gt 0 ]; then
    echo "error: git-tags does not accept any arguments" >&2
    return 1
  fi

  # git tag --list --sort=committerdate
}

main "$@"
