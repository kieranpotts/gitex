#!/bin/env sh
set -eu

#
# git-unstage - Alias for `git reset --mixed HEAD`, which just
# removes everything from the staging index, returning those
# changes to the working directory.
#
# Usage:
#   $ git unstage
#
# Dependencies: None
#

# shellcheck source=../lib/print.sh
. "$(dirname "$0")/../lib/print.sh"

main() {
  if [ $# -gt 0 ]; then
    print_error "git-unstage does not accept any arguments"
    return 1
  fi

  # TODO: Review draft implementation, below.

  git reset
}

main "$@"
