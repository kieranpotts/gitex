#!/bin/env sh
set -eu

#
# git-unignore - Stop ignoring changes made to a file.
#
# This command is the opposite of `git ignore`. Use `git ignored` to see a list
# of file paths that are currently ignored, and which can therefore be
# unignored.
#
# Usage:
#   $ git unignore [path]
#
# Dependencies: None
#

# shellcheck source=../lib/print.sh
. "$(dirname "$0")/../lib/print.sh"

main() {
  if [ $# -gt 0 ]; then
    print_error "git-unignore does not accept any arguments"
    return 1
  fi

  # TODO: Review draft implementation, below.

  file="${1}"

  if [ -z "${file}" ]; then
    echo "Require a file path" >&2
    exit 1
  fi

  # Reference:
  # https://mirrors.edge.kernel.org/pub/software/scm/git/docs/git-update-index.html
  git update-index --no-assume-unchanged "${file}"
}

main "$@"
