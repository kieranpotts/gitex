#!/bin/env sh
set -eu

#
# git-state - Concise view of `git status`.
#
# Provides a short-format view of the working tree's current state, with
# branch and tracking information added.
#
# Usage:
#   $ git state
#
# Dependencies: (none)
#

# shellcheck source=../lib/print.sh
. "$(dirname "$0")/../lib/print.sh"

main() {
  if [ $# -gt 0 ]; then
    print_error "git-state does not accept any options"
    return 1
  fi

  # TODO: Review draft implementation, below.

  git status --short --branch
}

main "$@"
