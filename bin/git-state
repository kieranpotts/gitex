#!/bin/env sh
set -eu

#
# git-state - Concise view of `git status`.
#
# Provides a short-format view of the working tree's current state, with
# branch and tracking information added.
#
# Usage:
#   $ git state
#
# Dependencies: None
#

main() {
  if [ $# -gt 0 ]; then
    echo "error: git-state does not accept any arguments" >&2
    return 1
  fi

  # git status --short --branch
}

main "$@"
