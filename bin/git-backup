#!/bin/env sh
set -eu

#
# git-backup - Create a backup of the current branch or another
# specified branch.
#
# Usage:
#   $ git backup [<branch>]
#
# Dependencies: None
#

# shellcheck source=../lib/print.sh
. "$(dirname "$0")/../lib/print.sh"

main() {
  if [ $# -gt 0 ]; then
    print_error "git-backup does not accept any options"
    return 1
  fi

  # TODO: Review draft implementation, below.

  branch="${1}"

  # Default to the current branch.
  if [ -z "${branch}" ]; then
    branch=$(git branch --show-current)
  fi

  git branch "backup/${branch}" "${branch}"
  print_info "Created branch 'backup/${branch}'"
}

main "$@"
