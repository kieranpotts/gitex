#!/bin/env sh
set -eu

#
# git-sw - Alias for `git switch`. Parameters are forwarded.
#
# Usage:
#   $ git sw ([params...])
#
# Dependencies: None
#

# shellcheck source=../lib/print.sh
. "$(dirname "$0")/../lib/print.sh"

main() {
  if [ $# -gt 0 ]; then
    print_error "git-sw does not accept any arguments"
    return 1
  fi

  # # Bash-compatible code, with string indexing that allows additional parameters
  # # to be passed on to the `git switch` command.
  # #git switch "${@:1}"

  # # POSIX-compatible code, without string indexing. This code only passes the
  # # first parameter to the `git switch` command, so only the branch name.
  # git switch "${1}"
}

main "$@"
