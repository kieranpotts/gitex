#!/bin/env sh
set -eu

#
# git-sw - Alias for `git switch`. Options are forwarded.
#
# Usage:
#   $ git sw [...]
#
# Dependencies: None
#

# shellcheck source=../lib/print.sh
. "$(dirname "$0")/../lib/print.sh"

main() {
  if [ $# -gt 0 ]; then
    print_error "git-sw does not accept any options"
    return 1
  fi

  # TODO: Review draft implementation, below.

  # Bash-compatible code, with string indexing that allows additional options
  # to be passed on to the `git switch` command.
  #git switch "${@:1}"

  # POSIX-compatible code, without string indexing. This code only passes the
  # first option to the `git switch` command, so only the branch name.
  git switch "${1}"
}

main "$@"
