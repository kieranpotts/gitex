#!/bin/env sh
set -eu

#
# git-remotes - List the URLs of all remotes.
#
# Usage:
#   $ git remotes
#
# Dependencies: None
#

# shellcheck source=../lib/print.sh
. "$(dirname "$0")/../lib/print.sh"

main() {
  if [ $# -gt 0 ]; then
    print_error "git-remotes does not accept any options"
    return 1
  fi

  # TODO: Review draft implementation, below.

  git remote -v
}

main "$@"
