#!/bin/env sh
set -eu

#
# git-last - Show detailed information on the changes in the last commit.
#
# Usage:
#   $ git last
#
# Dependencies: None
#

# shellcheck source=../lib/print.sh
. "$(dirname "$0")/../lib/print.sh"

main() {
  if [ $# -gt 0 ]; then
    print_error "git-last does not accept any options"
    return 1
  fi

  # TODO: Review draft implementation, below.

  git log -1 HEAD --stat

}

main "$@"
