#!/bin/env sh
set -eu

#
# git-ff - Perform a fast-forward merge.
#
# This operation fails if there is divergent work in the current (source) branch
# that is not in the target branch. In this situation, the current branch must
# be rebased on the target branch beforehand.
#
# Usage:
#   $ git ff [<branch>]
#
# Dependencies: (none)
#

# shellcheck source=../lib/print.sh
. "$(dirname "$0")/../lib/print.sh"

main() {
  if [ $# -gt 0 ]; then
    print_error "git-ff does not accept any options"
    return 1
  fi

  # TODO: Review draft implementation, below.

  branch=${1:-main}
  #branch="${1}"

  if [ -z "${branch}" ]; then
    # Bash-compatible code:
    #read -p "Type a branch name: " branch

    # Posix-compatible code:
    printf "Type a branch name: " >&2
    read -r branch
  fi

  if [ -z "${branch}" ]; then
    echo "Require branch name" >&2
    exit 1
  fi

  git merge --ff-only "${branch}"
}

main "$@"
