#!/bin/env sh
set -eu

#
# git-wip - Save work-in-progress.
#
# Creates a commit, with the contents of the staging index plus
# working directory, with the specified message (or "WIP" if no
# message is provided). Continue where you left off tomorrow
# with `git resume`.
#
# Usage:
#   $ git wip ('[msg]')
#
# Dependencies: None
#

main() {
  if [ $# -gt 0 ]; then
    echo "error: git-wip does not accept any arguments" >&2
    return 1
  fi

  # ...
}

main "$@"
