#!/bin/env sh
set -eu

#
# git-stashed - Show the current number of entries in the stash.
#
# Usage:
#   $ git stashed
#
# Dependencies: None
#

main() {
  if [ $# -gt 0 ]; then
    echo "error: git-stashed does not accept any arguments" >&2
    return 1
  fi

  # git status --show-stash
}

main "$@"
