#!/bin/env sh
set -eu

#
# git-stashed - Show the current number of entries in the stash.
#
# Usage:
#   $ git stashed
#
# Dependencies: None
#

# shellcheck source=../lib/print.sh
. "$(dirname "$0")/../lib/print.sh"

main() {
  if [ $# -gt 0 ]; then
    print_error "git-stashed does not accept any options"
    return 1
  fi

  # TODO: Review draft implementation, below.

  git status --show-stash
}

main "$@"
