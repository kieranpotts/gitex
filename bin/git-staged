#!/bin/env sh
set -eu

#
# git-staged - List files that have changes staged for committing.
#
# See also the `git-working` script, which lists files with unstaged changes in
# the repository's working tree, and `git-changes`, which lists all files
# changed since the last commit, whether or not those changes have been staged.
#
# Usage:
#   $ git staged
#
# Dependencies: None
#

# shellcheck source=../lib/print.sh
. "$(dirname "$0")/../lib/print.sh"

main() {
  if [ $# -gt 0 ]; then
    echo "error: git-staged does not accept any arguments" >&2
    return 1
  fi

  # git diff --stat --staged HEAD
}

main "$@"
