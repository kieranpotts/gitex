#!/bin/env sh
set -eu

#
# git-working - List all files with changes in the working tree.
#
# Excludes files with all changes staged.
#
# See also `git-staged`, which shows the changes staged for committing, and
# `git changes`, which shows staged plus unstaged working changes.
#
# Usage:
#   $ git working
#
# Dependencies: None
#

# shellcheck source=../lib/print.sh
. "$(dirname "$0")/../lib/print.sh"

main() {
  if [ $# -gt 0 ]; then
    echo "error: git-working does not accept any arguments" >&2
    return 1
  fi

  # One of these:
  # git diff --name-only
  # git diff --stat
}

main "$@"
