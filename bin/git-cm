#!/bin/env sh
set -eu

#
# git-cm - Easier way to make commits.
#
# If changes have been staged, only those changes will be committed, and other
# changes will be left in the working tree. If no changes have been staged, all
# changes in the working tree will be automatically staged before being committed
# in full.
#
# Files that should remain untracked will need to be added to `gitignore`
# rules. See https://git-scm.com/docs/gitignore.
#
# Usage:
#   $ git cm [<msg>]
#
# Dependencies: (none)
#

# shellcheck source=../lib/print.sh
. "$(dirname "$0")/../lib/print.sh"

main() {
  if [ $# -gt 0 ]; then
    print_error "git-cm does not accept any options"
    return 1
  fi

  # TODO: Review draft implementation, below.

  # Capture optional message from the command line.
  msg="${1}"

  # Print an empty line before the command's main output.
  printf "\n"

  # If the user has supplied a commit message, commit it verbatim.
  if [ -n "${msg}" ]; then

    staged=$(git diff --stat --cached)
    if [ -z "${staged}" ]; then
      printf "%bgit add --all%b\n" "${DIM}" "${RESET}"
      git add --all
    fi

    printf "%bgit commit --quiet --message \"${msg}\"%b\n" "${DIM}" "${RESET}"
    git commit --quiet --message "${msg}"

    exit 0

  fi

  # TODO: Else prompt the user for the commit message.
}

main "$@"
