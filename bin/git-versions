#!/bin/env sh
set -eu

#
# git-versions - List tags prefixed with the lowercase letter "v",
# sorted numerically.
#
# Usage:
#   $ git versions
#
# Dependencies: None
#

# shellcheck source=../lib/print.sh
. "$(dirname "$0")/../lib/print.sh"

main() {
  if [ $# -gt 0 ]; then
    print_error "git-versions does not accept any options"
    return 1
  fi

  # TODO: Review draft implementation, below.

  git tag --list --sort=-version:refname v*
}

main "$@"
