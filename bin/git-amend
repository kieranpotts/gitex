#!/bin/env sh
set -eu

#
# git-amend - Modify the last commit with new changes.
#
# If there are staged changes, amend the last commit with those changes but
# leave the working tree as it is. If nothing is staged, stage all working
# changes (including new untracked files) and add those to the last commit.
#
# Usage:
#   $ git amend
#
# Dependencies: None
#

# shellcheck source=../lib/print.sh
. "$(dirname "$0")/../lib/print.sh"

main() {
  if [ $# -gt 0 ]; then
    print_error "git-amend does not accept any arguments"
    return 1
  fi

  # Check if there's a previous commit to amend.
  if ! git rev-parse --verify HEAD >/dev/null 2>&1; then
    print_error "no commits exist to amend"
    return 1
  fi

  # Check if there are staged changes. If there are, amend the
  # last commit with those changes only; leave other changes in
  # the working directory. Do not edit the commit message. Return
  # the exit code of the commit operation.
  if ! git diff --cached --quiet 2>/dev/null; then
    git commit --amend --no-edit
    return $?
  fi

  # No staged changes, check for working changes.
  has_unstaged=false
  has_untracked=false

  if ! git diff --quiet 2>/dev/null; then
    has_unstaged=true
  fi

  if [ -n "$(git ls-files --others --exclude-standard 2>/dev/null)" ]; then
    has_untracked=true
  fi

  # If there are working changes, stage all and amend. Return
  # the exit code of the commit operation.
  if [ "$has_unstaged" = true ] || [ "$has_untracked" = true ]; then
    git add --all
    git commit --amend --no-edit
    return $?
  fi

  # No changes to amend.
  print_info "nothing to amend, working tree clean"
  return 0
}

main "$@"
