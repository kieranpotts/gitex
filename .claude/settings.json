{
  "permissions": {
    "allow": [
      "Bash(git *)",
      "Read"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "cd /workspace/repos/gitex && ./fix && ./check 2>&1 || true",
            "statusMessage": "Running fix and check..."
          }
        ]
      }
    ]
  }
}
